
<div class="delivery-check-box">
<input type="text" id="pincheck" placeholder="Enter delivery pincode"/>
<button id="checkpinbtn">Check Availability</button>
<div id="delivery-result"></div>
</div>

<script>
require(['jquery'],function($){
$('#checkpinbtn').click(function(){
var pin=$('#pincheck').val();
$('#delivery-result').html('Checking delivery...');
$.post('<?= $block->escapeUrl($block->getUrl("checkdelivery/ajax/check")) ?>',{pincode:pin},function(res){
$('#delivery-result').html(res.message);
});
});
});
</script>
